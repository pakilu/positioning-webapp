@model App.Domain.Chip

@{
    ViewData["Title"] = "Edit chip";
}

<h1>Edit chip</h1>

<h4>Physical device</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DeviceIdentifier" class="control-label">MAC address / device ID</label>
                <input asp-for="DeviceIdentifier" class="form-control" autocomplete="off" placeholder="24:6F:28:AA:BB:01" />
                <span asp-validation-for="DeviceIdentifier" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to chips</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const deviceInput = document.getElementById("DeviceIdentifier");
        deviceInput?.addEventListener("blur", () => {
            const cleaned = deviceInput.value.trim().replace(/[-\s]/g, ":").toUpperCase();
            const compact = cleaned.replace(/:/g, "");
            deviceInput.value = compact.length === 12
                ? compact.match(/.{1,2}/g).join(":")
                : cleaned;
        });
    </script>
}
